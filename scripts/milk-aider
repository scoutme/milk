#!/usr/bin/env python3
"""
milk-aider — subprocess bridge between milk and aider-chat.

Implements the milk subprocess protocol: emits NDJSON on stdout so that
milk's Go subprocess runner can parse it. Designed to be invoked per-turn
by milk's aider-cli provider.

Install: pip install aider-chat
Usage: milk-aider [options] -- "user prompt"
"""

import argparse
import json
import os
import sys


def emit(obj: dict):
    print(json.dumps(obj), flush=True)


def run(args):
    # Read and concatenate context files (static + dynamic system prompt injection).
    instructions_parts = []
    for path in args.append_system_prompt_file or []:
        try:
            with open(path) as f:
                instructions_parts.append(f.read().strip())
        except OSError:
            pass
    instructions = "\n\n".join(p for p in instructions_parts if p) or None

    emit({
        "type": "system",
        "session_id": args.session_id or "",
        "agent": "aider",
        "version": "1",
    })

    prompt = " ".join(args.prompt)
    input_tokens = 0
    output_tokens = 0
    cost_usd = 0.0

    # Build the aider command. We use aider's --yes-always (non-interactive) mode
    # and capture output by running it as a subprocess, then relay stdout as
    # text_delta events so the milk TUI streams the response live.
    import subprocess
    import threading

    aider_cmd = ["aider", "--yes-always", "--no-pretty", "--no-git"]

    if args.model:
        aider_cmd += ["--model", args.model]
    if args.api_base:
        aider_cmd += ["--openai-api-base", args.api_base]
    if args.api_key:
        aider_cmd += ["--openai-api-key", args.api_key]
    if args.auto_commits:
        aider_cmd += ["--auto-commits"]
    else:
        aider_cmd += ["--no-auto-commits"]
    for f in args.files or []:
        aider_cmd += [f]
    aider_cmd += args.extra_aider_args

    if instructions:
        # Write instructions to a temp file and pass via --read.
        import tempfile
        tmp = tempfile.NamedTemporaryFile(mode="w", suffix=".md", delete=False, prefix="milk-aider-ctx-")
        try:
            tmp.write(instructions)
            tmp.close()
            aider_cmd += ["--read", tmp.name]
        except OSError:
            pass

    # Pass the prompt via stdin in message mode.
    aider_cmd += ["--message", prompt]

    if not args.api_key:
        emit({"type": "result", "is_error": True, "error": "no API key available (token_cmd returned empty or api_key not set)"})
        sys.exit(1)

    env = dict(os.environ)
    env.pop("ANTHROPIC_API_KEY", None)
    env.pop("OPENAI_API_KEY", None)
    env["OPENAI_API_KEY"] = args.api_key

    try:
        proc = subprocess.Popen(
            aider_cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            stdin=subprocess.DEVNULL,
            text=True,
            env=env,
        )

        # Stream stdout line by line as text_delta events.
        for line in proc.stdout:
            # Skip aider's own decoration lines (dashes, prompts).
            stripped = line.rstrip("\n")
            if stripped.startswith("─") or stripped.startswith("Aider v"):
                continue
            emit({"type": "text_delta", "text": line})

        proc.wait()
        if proc.returncode != 0:
            emit({"type": "result", "is_error": True, "error": f"aider exited with code {proc.returncode}"})
            sys.exit(1)

    except FileNotFoundError:
        emit({"type": "result", "is_error": True, "error": "aider not found — run: pip install aider-chat"})
        sys.exit(1)
    except Exception as exc:
        emit({"type": "result", "is_error": True, "error": str(exc)})
        sys.exit(1)

    emit({
        "type": "result",
        "is_error": False,
        "input_tokens": input_tokens,
        "output_tokens": output_tokens,
        "total_cost_usd": cost_usd,
    })


def main():
    parser = argparse.ArgumentParser(
        description="milk subprocess bridge for aider-chat",
        add_help=True,
    )
    parser.add_argument("--model", default="",
                        help="model identifier (e.g. gpt-4.1, claude-opus-4-5)")
    parser.add_argument("--api-base", default=None,
                        help="OpenAI-compatible API base URL")
    parser.add_argument("--api-key", default=None,
                        help="API key / Bearer token")
    parser.add_argument("--auto-commits", action="store_true", default=False,
                        help="enable aider's auto-commit behaviour")
    parser.add_argument("--files", nargs="*", default=[],
                        help="files/globs to add to the aider session")
    parser.add_argument("--session-id", default="",
                        help="informational session ID echoed in the system event")
    parser.add_argument("--append-system-prompt-file", action="append",
                        dest="append_system_prompt_file", metavar="PATH",
                        help="file whose contents are appended to the system prompt (may be repeated)")
    parser.add_argument("prompt", nargs=argparse.REMAINDER,
                        help="user prompt (after --)")

    args, extra_aider_args = parser.parse_known_args()

    # Strip leading "--" separator that milk passes before the prompt.
    if args.prompt and args.prompt[0] == "--":
        args.prompt = args.prompt[1:]
    args.extra_aider_args = extra_aider_args

    if not args.prompt:
        parser.error("prompt is required")

    try:
        run(args)
    except Exception as exc:
        emit({"type": "result", "is_error": True, "error": str(exc)})
        sys.exit(1)


if __name__ == "__main__":
    main()
